# ─────────────────────────────────────────────────────────────────────────────
# CI/CD Seminar Provisioner — Environment Variables
# Copy this file to .env and fill in real values before running provision.py
# ─────────────────────────────────────────────────────────────────────────────

# Hetzner Cloud API token (read/write permissions required)
HCLOUD_TOKEN=your-hetzner-api-token-here

# Cloudflare API token — needs Zone:DNS:Edit permission for the target zone
CF_API_TOKEN=your-cloudflare-api-token-here

# Cloudflare Zone ID for cicd.it-scholar.com
# Found in the Cloudflare dashboard → right sidebar on the zone overview page
CF_ZONE_ID=your-cloudflare-zone-id-here

# Path to the SSH key pair used by the provisioner to access all VMs
# The public key is uploaded to Hetzner; the private key is used by Fabric/Paramiko.
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
